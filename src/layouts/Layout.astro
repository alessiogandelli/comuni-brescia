---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
}

const { title, description, canonicalUrl } = Astro.props;
const siteTitle = 'Comuni Brescia';
const fullTitle = title === siteTitle ? title : `${title} | ${siteTitle}`;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a class="site-logo" href={base || '/'}>📍 {siteTitle}</a>
        <nav class="site-nav" aria-label="Navigazione principale">
          <a href={base || '/'}>Home</a>
          <a href={`${base}/comuni`}>Comuni</a>
          <a class="nav-cta" href="https://app.ranturismo.com/randocomune" target="_blank" rel="noopener">
            🎲 Randocomune
          </a>
        </nav>
      </div>
    </header>

    <main>
      <div class="container">
        <slot />
      </div>
    </main>

    <footer class="site-footer">
      <div class="container">
        <div class="footer-brand">
          <strong>📍 Comuni Brescia</strong>
          <span>Guida ai comuni della provincia di Brescia</span>
          <span>© {new Date().getFullYear()}</span>
        </div>
        <div class="footer-links">
          <a href={base || '/'}>Home</a>
          <a href={`${base}/comuni`}>Tutti i comuni</a>
          <a
            class="footer-rando-link"
      href="https://app.ranturismo.com/randocomune"
            target="_blank"
            rel="noopener"
          >
            🎲 Scopri Randocomune
          </a>
        </div>
      </div>
    </footer>
  </body>
</html>

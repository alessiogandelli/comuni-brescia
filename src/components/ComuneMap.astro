---
interface Props {
  name: string;
  coordinates: [number, number];
}

const { name, coordinates } = Astro.props;

const mapId = `map-${name.replace(/\s+/g, '-').toLowerCase()}`;
const boundariesUrl = `${import.meta.env.BASE_URL}comuni-boundaries.json`;
---

<div
  class="comune-map h-full min-h-[220px] overflow-hidden rounded-2xl border border-white/25 bg-white/10 shadow-lg shadow-black/5 md:min-h-[260px]"
  data-name={name}
  data-coords={JSON.stringify(coordinates)}
  data-map-id={mapId}
  data-boundaries-url={boundariesUrl}
>
  <div class="map-container w-full h-full" id={mapId}></div>
</div>

<script>
  // @ts-nocheck
  const FILL_COLOR = '#8b5cf6';
  const STROKE_COLOR = '#8b5cf6';

  function getPolygonCoords(geometry) {
    if (geometry.type === 'MultiPolygon') {
      return geometry.coordinates[0]?.[0] ?? [];
    }

    return geometry.coordinates[0] ?? [];
  }

  async function initMaps() {
    const maps = document.querySelectorAll('.comune-map');

    if (maps.length === 0) return;

    const L = await import('leaflet');
    const leaflet = L.default || L;

    await import('leaflet/dist/leaflet.css');

    for (const mapEl of maps) {
      const name = mapEl.getAttribute('data-name');
      const mapId = mapEl.getAttribute('data-map-id');
      const boundariesUrl = mapEl.getAttribute('data-boundaries-url');
      const container = document.getElementById(mapId || '');

      if (!name || !container || !boundariesUrl) {
        console.warn('Missing map config', { name, mapId, boundariesUrl });
        continue;
      }

      try {
        const res = await fetch(boundariesUrl);

        if (!res.ok) {
          throw new Error(`Boundaries request failed with ${res.status}`);
        }

        const data = await res.json();
        const feature = data.features.find(
          (feature) => feature.properties?.name === name
        );

        if (!feature) {
          console.warn('No boundary found for:', name);
          container.innerHTML = `<div class="flex items-center justify-center h-full text-white/50 text-sm">Mappa non disponibile</div>`;
          continue;
        }

        const geometry = feature.geometry;
        const coords = getPolygonCoords(geometry);

        if (coords.length === 0) {
          throw new Error(`Unsupported geometry for ${name}`);
        }

        const map = leaflet.map(container, {
          zoomControl: false,
          dragging: false,
          scrollWheelZoom: false,
          doubleClickZoom: false,
          touchZoom: true,
          attributionControl: false,
        });

        const coordsArr = coords.map((coordinate) => [coordinate[1], coordinate[0]]);

        const layer = leaflet.polygon(coordsArr, {
          color: STROKE_COLOR,
          weight: 2,
          fillColor: FILL_COLOR,
          fillOpacity: 0.35,
        }).addTo(map);

        map.fitBounds(layer.getBounds(), { padding: [20, 20], maxZoom: 13 });

        container.style.background = 'transparent';
      } catch (e) {
        console.error('Map failed for', name, e);
        if (container) {
          container.innerHTML = `<div class="flex items-center justify-center h-full text-white/50 text-sm">Errore caricamento</div>`;
        }
      }
    }
  }

  initMaps();
</script>
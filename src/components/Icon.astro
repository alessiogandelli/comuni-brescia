const iconPath = icons[name];
if (!iconPath) {
  console.warn(`Icon "${name}" not found`);
}
---

{iconPath && (
  <svg 
    xmlns="http://www.w3.org/2000/svg" 
    width={size} 
    height={size} 
    viewBox="0 0 24 24" 
    fill="none" 
    stroke="currentColor" 
    stroke-width="2" 
    stroke-linecap="round" 
    stroke-linejoin="round"
    class={className}
    aria-hidden="true"
  >
    {iconPath.split(' M').filter(Boolean).map((path) => (
      <path d={`M${path}`} />
    ))}
  </svg>
)}

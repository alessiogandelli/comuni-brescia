---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<footer class="mt-12 mb-4 border-t border-border/40 pt-6">
  <div class="flex flex-wrap items-center justify-center gap-x-4 gap-y-1 text-[11px] text-muted-foreground/60">
    <a href={`${base}/privacy`} class="hover:text-foreground transition-colors">Privacy Policy</a>
    <span>·</span>
    <a href={`${base}/terms`} class="hover:text-foreground transition-colors">Termini</a>
    <span>·</span>
    <a href={`${base}/contact`} class="hover:text-foreground transition-colors">Contatto</a>
  </div>
  <p class="text-center text-[10px] text-muted-foreground/40 mt-2">© 2026 Ranturismo</p>
</footer>
---
import Icon from './Icon.astro';

export interface Props {
  comune: {
    slug: string;
    name: string;
    population: number;
    area?: number;
    elevation?: number;
    poiCount?: number;
    hasHistoric?: boolean;
    hasNature?: boolean;
    hasSport?: boolean;
    hasFood?: boolean;
    hasAccommodation?: boolean;
    hasStation?: boolean;
    fact?: string;
  };
}

const { comune } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Format numbers with Italian locale
const formatNumber = (num: number) => num.toLocaleString('it-IT');

// Category features
const features = [
  { key: 'hasHistoric', icon: 'landmark', label: 'Patrimonio storico' },
  { key: 'hasNature', icon: 'tree-pine', label: 'Natura' },
  { key: 'hasSport', icon: 'bike', label: 'Sport' },
  { key: 'hasFood', icon: 'utensils', label: 'Ristorazione' },
  { key: 'hasAccommodation', icon: 'bed', label: 'Alloggi' },
  { key: 'hasStation', icon: 'train', label: 'Stazione ferroviaria' },
];

const activeFeatures = features.filter(f => comune[f.key as keyof typeof comune]);

// Determine card accent color based on primary feature
let cardAccent = '#3B82F6'; // default blue
if (comune.hasHistoric) cardAccent = '#F59E0B'; // amber
else if (comune.hasNature) cardAccent = '#10B981'; // emerald
else if (comune.hasFood) cardAccent = '#EF4444'; // red
else if (comune.hasSport) cardAccent = '#F59E0B'; // amber
---

<article class="card" style={`--card-accent: ${cardAccent}`}>
  <div class="card-content">
    <div class="card-header">
      <h3 class="card-title">{comune.name}</h3>
      {comune.poiCount && comune.poiCount > 0 && (
        <span class="poi-count" title={`${comune.poiCount} punti di interesse`}>
          {comune.poiCount}
        </span>
      )}
    </div>

    <div class="card-stats">
      <div class="card-stat">
        <Icon name="building-2" size={14} />
        <span>{formatNumber(comune.population)} ab.</span>
      </div>
      {comune.area && (
        <div class="card-stat">
          <Icon name="square" size={14} />
          <span>{comune.area.toFixed(1)} km²</span>
        </div>
      )}
      {comune.elevation && (
        <div class="card-stat">
          <Icon name="mountain" size={14} />
          <span>{comune.elevation} m</span>
        </div>
      )}
    </div>

    {activeFeatures.length > 0 && (
      <div class="card-badges">
        {activeFeatures.slice(0, 6).map(feature => (
          <span class="mini-badge" title={feature.label}>
            <Icon name={feature.icon} size={14} />
          </span>
        ))}
      </div>
    )}

    {comune.fact && (
      <div class="card-fact">
        <Icon name="lightbulb" size={14} />
        <span>{comune.fact.substring(0, 80)}{comune.fact.length > 80 ? '...' : ''}</span>
      </div>
    )}

    <div class="card-footer">
      <a href={`${base}/comuni/${comune.slug}`} class="card-link">
        Scopri di più
        <Icon name="arrow-right" size={14} />
      </a>
    </div>
  </div>
</article>

<style>
  .card {
    position: relative;
    background-color: #FFFFFF;
    border: 1px solid #E2E8F0;
    border-radius: 0.75rem;
    overflow: hidden;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.08), 0 4px 6px -4px rgba(0, 0, 0, 0.05);
    border-color: var(--card-accent);
  }

  .card-content {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .card-title {
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: #0F172A;
    margin: 0;
    line-height: 1.3;
    letter-spacing: -0.025em;
  }

  .poi-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: var(--card-accent);
    color: #fff;
    font-size: 0.6875rem;
    font-weight: 700;
    padding: 0.25rem 0.5rem;
    border-radius: 0.5rem;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .card-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .card-stat {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.8125rem;
    color: #64748B;
    font-weight: 500;
  }

  .card-stat svg {
    color: var(--card-accent);
  }

  .card-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-bottom: 0.75rem;
  }

  .mini-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background-color: #F8FAFC;
    border: 1px solid #E2E8F0;
    border-radius: 0.5rem;
    color: var(--card-accent);
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .mini-badge:hover {
    background-color: var(--card-accent);
    border-color: var(--card-accent);
    color: #fff;
    transform: scale(1.1);
  }

  .card-fact {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: #78350f;
    background: #FEF3C7;
    border-left: 2px solid #F59E0B;
    padding: 0.625rem 0.75rem;
    margin: 0.75rem 0;
    border-radius: 0.375rem;
    line-height: 1.5;
  }

  .card-fact svg {
    flex-shrink: 0;
    margin-top: 0.125rem;
    color: #F59E0B;
  }

  .card-footer {
    margin-top: auto;
    padding-top: 0.75rem;
  }

  .card-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--card-accent);
    transition: gap 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .card-link:hover {
    text-decoration: none;
    gap: 0.625rem;
  }
</style>

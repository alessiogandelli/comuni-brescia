---
import Icon from './Icon.astro';

export interface Props {
  comune: {
    slug: string;
    name: string;
    population: number;
    area?: number;
    elevation?: number;
    poiCount?: number;
    hasHistoric?: boolean;
    hasNature?: boolean;
    hasSport?: boolean;
    hasFood?: boolean;
    hasAccommodation?: boolean;
    hasStation?: boolean;
    fact?: string;
  };
}

const { comune } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const formatNumber = (num: number) => num.toLocaleString('it-IT');

const features = [
  { key: 'hasHistoric', icon: 'landmark', label: 'Patrimonio storico' },
  { key: 'hasNature', icon: 'tree-pine', label: 'Natura' },
  { key: 'hasSport', icon: 'bike', label: 'Sport' },
  { key: 'hasFood', icon: 'utensils', label: 'Ristorazione' },
  { key: 'hasAccommodation', icon: 'bed', label: 'Alloggi' },
  { key: 'hasStation', icon: 'train', label: 'Stazione ferroviaria' },
];

const activeFeatures = features.filter(f => comune[f.key as keyof typeof comune]);

let cardAccent = 'hsl(var(--primary))';
if (comune.hasHistoric) cardAccent = '#F59E0B';
else if (comune.hasNature) cardAccent = '#10B981';
else if (comune.hasFood) cardAccent = '#EF4444';
else if (comune.hasSport) cardAccent = '#F59E0B';
---

<article class="group relative bg-card border border-border rounded-xl overflow-hidden transition-all duration-200 hover:-translate-y-1 hover:shadow-lg hover:border-primary/30 flex flex-col" style={`--card-accent: ${cardAccent}`}>
  <div class="p-5 flex flex-col flex-1">
    <div class="flex items-start justify-between gap-3 mb-3">
      <h3 class="text-xl font-bold text-foreground leading-tight tracking-tight">{comune.name}</h3>
      {comune.poiCount && comune.poiCount > 0 && (
        <span class="inline-flex items-center justify-center shrink-0 text-xs font-bold px-2 py-1 rounded-lg bg-primary text-primary-foreground" title={`${comune.poiCount} punti di interesse`}>
          {comune.poiCount}
        </span>
      )}
    </div>

    <div class="flex flex-wrap gap-4 mb-3 text-sm text-muted-foreground">
      <div class="flex items-center gap-1.5">
        <Icon name="building-2" size={14} class="text-primary" />
        <span>{formatNumber(comune.population)} ab.</span>
      </div>
      {comune.area && (
        <div class="flex items-center gap-1.5">
          <Icon name="square" size={14} class="text-primary" />
          <span>{comune.area.toFixed(1)} km²</span>
        </div>
      )}
      {comune.elevation && (
        <div class="flex items-center gap-1.5">
          <Icon name="mountain" size={14} class="text-primary" />
          <span>{comune.elevation} m</span>
        </div>
      )}
    </div>

    {activeFeatures.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-3">
        {activeFeatures.slice(0, 6).map(feature => (
          <span class="inline-flex items-center justify-center w-7 h-7 bg-accent border border-border rounded-md transition-all group-hover:scale-110" title={feature.label}>
            <Icon name={feature.icon} size={14} class="text-foreground" />
          </span>
        ))}
      </div>
    )}

    {comune.fact && (
      <div class="flex items-start gap-2 text-sm bg-secondary/50 border-l-2 border-primary px-3 py-2 rounded-r-md my-2">
        <Icon name="lightbulb" size={14} class="text-primary shrink-0 mt-0.5" />
        <span class="text-foreground/80 leading-relaxed">{comune.fact.substring(0, 80)}{comune.fact.length > 80 ? '...' : ''}</span>
      </div>
    )}

    <div class="mt-auto pt-3">
      <a href={`${base}/comuni/${comune.slug}`} class="inline-flex items-center gap-1.5 text-sm font-semibold text-primary hover:gap-2.5 transition-all">
        Scopri di più
        <Icon name="arrow-right" size={14} />
      </a>
    </div>
  </div>
</article>
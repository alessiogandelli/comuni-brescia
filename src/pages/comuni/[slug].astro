---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Icon from '../../components/Icon.astro';
import ComuneMap from '../../components/ComuneMap.astro';

export async function getStaticPaths() {
  const comuni = await getCollection('comuni');
  return comuni.map((comune) => ({
    params: { slug: comune.id },
    props: { comune },
  }));
}

const { comune } = Astro.props;
const { Content } = await render(comune);

const allComuni = await getCollection('comuni');
const nearbyComuni = comune.data.nearby
  .map((slug) => allComuni.find((c) => c.id === slug))
  .filter(Boolean) as CollectionEntry<'comuni'>[];

const borderingComuni = comune.data.bordering
  ? comune.data.bordering
      .map((slug) => allComuni.find((c) => c.id === slug))
      .filter(Boolean) as CollectionEntry<'comuni'>[]
  : [];

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const pageDescription = comune.data.intro 
  ? comune.data.intro.substring(0, 160)
  : `Scopri ${comune.data.name}: cosa fare, luoghi importanti, storia e informazioni utili sul comune della provincia di ${comune.data.province}.`;
  
const canonicalUrl = `${import.meta.env.SITE}${base}/comuni/${comune.id}`;

const formatNumber = (num: number | undefined) => num?.toLocaleString('it-IT') || '—';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Place',
  name: comune.data.name,
  description: pageDescription,
  geo: {
    '@type': 'GeoCoordinates',
    latitude: comune.data.coordinates[0],
    longitude: comune.data.coordinates[1],
  },
  ...(comune.data.population && {
    containedInPlace: {
      '@type': 'AdministrativeArea',
      name: `Provincia di ${comune.data.province}`,
    },
  }),
  url: canonicalUrl,
};
---

<Layout
  title={comune.data.name}
  description={pageDescription}
  canonicalUrl={canonicalUrl}
  type="article"
>
  <header class={`relative text-foreground overflow-hidden -mx-4 -mt-8 px-4 pt-8 pb-8 rounded-[1.75rem] mb-8 sm:-mx-6 sm:-mt-12 sm:px-6 sm:pt-12 sm:pb-10 sm:rounded-3xl sm:mb-10`}>
    <div class="absolute inset-0 opacity-10" style="background-image: url(&quot;data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E&quot;);"></div>
    
    <div class="relative z-10 grid gap-6 md:grid-cols-5 md:gap-8 md:items-center">
      <div class="order-2 md:order-1 md:col-span-3">
        <div class="mb-4 flex flex-wrap items-center gap-3">
        <a href={`${base}/comuni`} class="inline-flex items-center gap-2 text-sm font-medium opacity-80 hover:opacity-100 transition-opacity">
          <Icon name="arrow-left" size={16} />
          Tutti i comuni
        </a>
      </div>
      
      <h1 class="mb-4 text-3xl font-black tracking-tight leading-[1.05] sm:text-5xl lg:text-6xl">
        {comune.data.name}
      </h1>
      
      <span class="inline-flex items-center gap-2 rounded-full border border-white/30 bg-white/20 px-4 py-2 text-sm font-semibold backdrop-blur-sm">
        <Icon name="map-pin" size={14} />
        Provincia di {comune.data.province}
      </span>

      <div class="mt-6 grid max-w-xl grid-cols-1 gap-3 sm:grid-cols-2 xl:grid-cols-4">
        <div class="bg-white/15 backdrop-blur-sm border border-white/25 rounded-xl p-3">
          <div class="flex items-center gap-2">
            <Icon name="users" size={18} class="opacity-90" />
            <div>
              <div class="text-lg font-bold">{formatNumber(comune.data.population)}</div>
              <div class="text-xs opacity-80 uppercase tracking-wide">Abitanti</div>
            </div>
          </div>
        </div>

        {comune.data.area && (
          <div class="bg-white/15 backdrop-blur-sm border border-white/25 rounded-xl p-3">
            <div class="flex items-center gap-2">
              <Icon name="maximize" size={18} class="opacity-90" />
              <div>
                <div class="text-lg font-bold">{comune.data.area.toFixed(1)} km²</div>
                <div class="text-xs opacity-80 uppercase tracking-wide">Superficie</div>
              </div>
            </div>
          </div>
        )}

        {comune.data.elevation && (
          <div class="bg-white/15 backdrop-blur-sm border border-white/25 rounded-xl p-3">
            <div class="flex items-center gap-2">
              <Icon name="mountain" size={18} class="opacity-90" />
              <div>
                <div class="text-lg font-bold">{comune.data.elevation} m</div>
                <div class="text-xs opacity-80 uppercase tracking-wide">Altitudine</div>
              </div>
            </div>
          </div>
        )}

        {comune.data.poiCount && comune.data.poiCount > 0 && (
          <div class="bg-white/15 backdrop-blur-sm border border-white/25 rounded-xl p-3">
            <div class="flex items-center gap-2">
              <Icon name="map-pin" size={18} class="opacity-90" />
              <div>
                <div class="text-lg font-bold">{comune.data.poiCount}</div>
                <div class="text-xs opacity-80 uppercase tracking-wide">POI</div>
              </div>
            </div>
          </div>
        )}
      </div>

      </div>

      <div class="order-1 md:order-2 md:col-span-2">
        <ComuneMap name={comune.data.name} coordinates={comune.data.coordinates} />
      </div>
    </div>
  </header>

  {comune.data.intro && comune.data.intro.trim() && (
    <div class="mb-8 rounded-r-xl border-l-4 border-primary bg-primary/5 p-4 sm:mb-10 sm:p-6">
      <div class="flex gap-3 sm:gap-4">
        <Icon name="info" size={20} class="text-primary shrink-0 mt-0.5" />
        <p class="text-base leading-relaxed text-foreground sm:text-lg">{comune.data.intro}</p>
      </div>
    </div>
  )}

  <article class="prose prose-sm sm:prose-base lg:prose-lg max-w-none mb-8 sm:mb-10
    prose-headings:font-bold prose-headings:text-foreground prose-headings:tracking-tight
    prose-h2:text-xl sm:prose-h2:text-2xl prose-h2:mt-8 sm:prose-h2:mt-10 prose-h2:mb-4 prose-h2:pb-3 prose-h2:border-b prose-h2:border-border
    prose-h3:text-lg sm:prose-h3:text-xl prose-h3:mt-6 prose-h3:mb-3
    prose-p:text-muted-foreground prose-p:leading-relaxed
    prose-a:text-primary prose-a:no-underline hover:prose-a:underline
    prose-strong:text-foreground
    prose-ul:my-4 prose-li:my-1.5">
    <Content />
  </article>

  {comune.data.fact && comune.data.fact.trim() && (
    <aside class="mb-8 rounded-xl border-2 border-amber-200 bg-amber-50 p-4 dark:border-amber-800 dark:bg-amber-950/30 sm:mb-10 sm:p-6">
      <div class="flex gap-3 sm:gap-4">
        <Icon name="lightbulb" size={24} class="text-amber-600 dark:text-amber-400 shrink-0" />
        <div>
          <h3 class="text-lg font-bold text-foreground mb-2">Lo sapevi?</h3>
          <p class="text-foreground/80 leading-relaxed">{comune.data.fact}</p>
        </div>
      </div>
    </aside>
  )}

  {(borderingComuni.length > 0 || nearbyComuni.length > 0) && (
    <section class="mb-8 rounded-2xl border border-border bg-muted/50 p-4 sm:mb-10 sm:p-6 lg:p-8">
      <h2 class="mb-5 flex items-center gap-3 text-xl font-bold text-foreground sm:mb-6 sm:text-2xl">
        <Icon name="map" size={24} />
        Esplora i dintorni
      </h2>
      
      <div class="grid gap-4 md:grid-cols-2 md:gap-6">
        {borderingComuni.length > 0 && (
          <div class="rounded-xl border border-border bg-card p-4 sm:p-6">
            <h3 class="flex items-center gap-2 text-lg font-bold text-foreground mb-1">
              <Icon name="map" size={18} />
              Comuni confinanti
            </h3>
            <p class="text-sm text-muted-foreground mb-4">Comuni che condividono il confine</p>
            <ul class="space-y-2">
              {borderingComuni.map((bordering) => (
                <li>
                  <a 
                    href={`${base}/comuni/${bordering.id}`}
                    class="flex items-center gap-2 bg-secondary hover:bg-primary hover:border-primary text-secondary-foreground hover:text-primary-foreground border border-border hover:shadow-md px-4 py-3 rounded-lg font-medium transition-all hover:-translate-x-1"
                  >
                    <Icon name="map-pin" size={14} class="opacity-70" />
                    {bordering.data.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}

        {nearbyComuni.length > 0 && (
          <div class="rounded-xl border border-border bg-card p-4 sm:p-6">
            <h3 class="flex items-center gap-2 text-lg font-bold text-foreground mb-1">
              <Icon name="compass" size={18} />
              Comuni vicini
            </h3>
            <p class="text-sm text-muted-foreground mb-4">Altri comuni nelle vicinanze</p>
            <ul class="space-y-2">
              {nearbyComuni.map((nearby) => (
                <li>
                  <a 
                    href={`${base}/comuni/${nearby.id}`}
                    class="flex items-center gap-2 bg-secondary hover:bg-primary hover:border-primary text-secondary-foreground hover:text-primary-foreground border border-border hover:shadow-md px-4 py-3 rounded-lg font-medium transition-all hover:-translate-x-1"
                  >
                    <Icon name="map-pin" size={14} class="opacity-70" />
                    {nearby.data.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>
    </section>
  )}

  <div class="rounded-2xl border border-primary/20 bg-gradient-to-br from-primary/5 to-primary/10 p-5 sm:p-6 lg:p-8">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="flex-1 text-center md:text-left">
        <h3 class="mb-2 text-xl font-bold text-foreground sm:text-2xl">
          Esplora altri comuni
        </h3>
        <p class="text-muted-foreground">
          Hai visitato {comune.data.name}? Con <strong>Randocomune</strong> scopri un comune a caso e pianifica la prossima avventura nella provincia di Brescia.
        </p>
      </div>
      <a
        href="https://play.ranturismo.com/randocomune"
        target="_blank"
        rel="noopener noreferrer"
        class="group inline-flex items-center gap-3 bg-gradient-to-r from-violet-600 to-indigo-600 hover:from-violet-500 hover:to-indigo-500 text-white text-lg sm:text-xl font-bold px-8 py-4 rounded-xl shadow-lg shadow-violet-500/30 hover:shadow-xl hover:shadow-violet-500/40 hover:-translate-y-1 transition-all duration-300 whitespace-nowrap"
      >
        <Icon name="compass" size={24} />
        <span>Prova Randocomune</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-70 group-hover:opacity-100 group-hover:translate-x-1 transition-all">
          <path d="M5 12h14"></path>
          <path d="m12 5 7 7-7 7"></path>
        </svg>
      </a>
    </div>
  </div>
</Layout>
---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ComuneCard from '../../components/ComuneCard.astro';
import Icon from '../../components/Icon.astro';

const comuni = await getCollection('comuni');
comuni.sort((a, b) => a.data.name.localeCompare(b.data.name, 'it'));

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const totalPopulation = comuni.reduce((sum, c) => sum + c.data.population, 0);
const totalArea = comuni.reduce((sum, c) => sum + (c.data.area || 0), 0);
const comuniWithPOIs = comuni.filter((c) => c.data.poiCount && c.data.poiCount > 0).length;
const comuniWithHistoric = comuni.filter(c => c.data.hasHistoric).length;
---

<Layout
  title="Tutti i Comuni"
  description="Elenco completo dei comuni della provincia di Brescia con informazioni su popolazione, posizione e luoghi da visitare."
  canonicalUrl={`${import.meta.env.SITE}${base}/comuni`}
>
  <div class="text-center mb-12">
    <h1 class="text-4xl font-bold text-foreground mb-3 tracking-tight">Tutti i Comuni di Brescia</h1>
    <p class="text-muted-foreground max-w-xl mx-auto">Esplora i {comuni.length} comuni della provincia di Brescia con informazioni dettagliate su popolazione, luoghi da visitare e servizi.</p>
  </div>

  <div class="grid grid-cols-2 md:grid-cols-3 gap-4 mb-10">
    <div class="flex items-center justify-center gap-3 p-4 bg-card border border-border rounded-xl transition-all hover:-translate-y-0.5 hover:shadow-md hover:border-primary/20">
      <Icon name="map-pin" size={20} class="text-primary shrink-0" />
      <div class="text-left">
        <div class="text-2xl font-bold text-foreground">{comuni.length}</div>
        <div class="text-sm text-muted-foreground">comuni</div>
      </div>
    </div>
    <div class="flex items-center justify-center gap-3 p-4 bg-card border border-border rounded-xl transition-all hover:-translate-y-0.5 hover:shadow-md hover:border-primary/20">
      <Icon name="users" size={20} class="text-primary shrink-0" />
      <div class="text-left">
        <div class="text-2xl font-bold text-foreground">{(totalPopulation / 1000000).toFixed(2)}M</div>
        <div class="text-sm text-muted-foreground">abitanti</div>
      </div>
    </div>
    <div class="flex items-center justify-center gap-3 p-4 bg-card border border-border rounded-xl transition-all hover:-translate-y-0.5 hover:shadow-md hover:border-primary/20 col-span-2 md:col-span-1">
      <Icon name="maximize" size={20} class="text-primary shrink-0" />
      <div class="text-left">
        <div class="text-2xl font-bold text-foreground">{Math.round(totalArea)}</div>
        <div class="text-sm text-muted-foreground">km²</div>
      </div>
    </div>
  </div>

  <div class="mb-8">
    <div class="relative">
      <Icon name="search" size={18} class="absolute left-4 top-1/2 -translate-y-1/2 text-muted-foreground pointer-events-none" />
      <input
        type="search"
        id="search-input"
        placeholder="Cerca un comune..."
        aria-label="Cerca un comune"
        class="w-full pl-11 pr-4 py-3 border-2 border-input bg-background rounded-xl text-base outline-none transition-all placeholder:text-muted-foreground focus:border-primary focus:ring-4 focus:ring-primary/10 shadow-sm"
      />
    </div>
  </div>

  <div class="flex flex-wrap gap-3 mb-10 justify-center" id="feature-filters">
    <button 
      class="filter-badge" 
      data-filter="hasHistoric"
      data-color="#F59E0B"
      aria-pressed="false"
      title="Filtra per patrimonio storico"
    >
      <Icon name="landmark" size={16} />
      <span>Storico</span>
    </button>
    <button 
      class="filter-badge" 
      data-filter="hasNature"
      data-color="#10B981"
      aria-pressed="false"
      title="Filtra per natura"
    >
      <Icon name="tree-pine" size={16} />
      <span>Natura</span>
    </button>
    <button 
      class="filter-badge" 
      data-filter="hasSport"
      data-color="#3B82F6"
      aria-pressed="false"
      title="Filtra per sport"
    >
      <Icon name="bike" size={16} />
      <span>Sport</span>
    </button>
    <button 
      class="filter-badge" 
      data-filter="hasFood"
      data-color="#EF4444"
      aria-pressed="false"
      title="Filtra per ristorazione"
    >
      <Icon name="utensils" size={16} />
      <span>Ristorazione</span>
    </button>
    <button 
      class="filter-badge" 
      data-filter="hasAccommodation"
      data-color="#8B5CF6"
      aria-pressed="false"
      title="Filtra per alloggi"
    >
      <Icon name="bed" size={16} />
      <span>Alloggi</span>
    </button>
    <button 
      class="filter-badge" 
      data-filter="hasStation"
      data-color="#6366F1"
      aria-pressed="false"
      title="Filtra per stazione ferroviaria"
    >
      <Icon name="train" size={16} />
      <span>Stazione</span>
    </button>
    <button 
      class="clear-filters hidden" 
      id="clear-filters"
      title="Rimuovi tutti i filtri"
    >
      <Icon name="x" size={16} />
      <span>Pulisci filtri</span>
    </button>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="comuni-grid">
    {comuni.map((comune) => {
      const features = [];
      if (comune.data.hasHistoric) features.push('hasHistoric');
      if (comune.data.hasNature) features.push('hasNature');
      if (comune.data.hasSport) features.push('hasSport');
      if (comune.data.hasFood) features.push('hasFood');
      if (comune.data.hasAccommodation) features.push('hasAccommodation');
      if (comune.data.hasStation) features.push('hasStation');

      return (
        <div
          data-name={comune.data.name.toLowerCase()}
          data-features={features.join(',')}
        >
          <ComuneCard comune={{
            slug: comune.id,
            name: comune.data.name,
            population: comune.data.population,
            area: comune.data.area,
            elevation: comune.data.elevation,
            poiCount: comune.data.poiCount,
            hasHistoric: comune.data.hasHistoric,
            hasNature: comune.data.hasNature,
            hasSport: comune.data.hasSport,
            hasFood: comune.data.hasFood,
            hasAccommodation: comune.data.hasAccommodation,
            hasStation: comune.data.hasStation,
            fact: comune.data.fact,
          }} />
        </div>
      );
    })}
  </div>

  <p class="text-center text-muted-foreground text-base mt-10 italic" id="results-count"></p>
</Layout>

<script>
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const cards = document.querySelectorAll<HTMLElement>('#comuni-grid > div');
  const resultsCount = document.getElementById('results-count');
  const filterBadges = document.querySelectorAll<HTMLButtonElement>('.filter-badge');
  const clearFiltersBtn = document.getElementById('clear-filters') as HTMLButtonElement;
  
  const activeFilters = new Set<string>();

  function applyFilters() {
    const query = searchInput?.value.toLowerCase().trim() || '';
    let visibleCount = 0;

    cards.forEach((card) => {
      const name = card.dataset.name ?? '';
      const cardFeatures = card.dataset.features?.split(',').filter(Boolean) || [];
      
      const matchesSearch = !query || name.includes(query);
      const matchesFilters = activeFilters.size === 0 || 
        Array.from(activeFilters).every(filter => cardFeatures.includes(filter));

      const isVisible = matchesSearch && matchesFilters;
      card.style.display = isVisible ? '' : 'none';
      if (isVisible) visibleCount++;
    });

    if (resultsCount) {
      if (visibleCount === cards.length) {
        resultsCount.textContent = '';
      } else {
        resultsCount.textContent = `Visualizzati ${visibleCount} di ${cards.length} comuni`;
      }
    }
    
    if (clearFiltersBtn) {
      clearFiltersBtn.classList.toggle('hidden', activeFilters.size === 0);
    }
  }

  filterBadges.forEach((badge) => {
    badge.addEventListener('click', () => {
      const filter = badge.dataset.filter;
      if (!filter) return;
      
      const isActive = activeFilters.has(filter);
      
      if (isActive) {
        activeFilters.delete(filter);
        badge.setAttribute('aria-pressed', 'false');
        badge.classList.remove('active');
      } else {
        activeFilters.add(filter);
        badge.setAttribute('aria-pressed', 'true');
        badge.classList.add('active');
      }
      
      applyFilters();
    });
  });
  
  clearFiltersBtn?.addEventListener('click', () => {
    activeFilters.clear();
    filterBadges.forEach((badge) => {
      badge.setAttribute('aria-pressed', 'false');
      badge.classList.remove('active');
    });
    applyFilters();
  });

  searchInput?.addEventListener('input', applyFilters);
  applyFilters();
  
  if (typeof IntersectionObserver !== 'undefined') {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry, index) => {
        if (entry.isIntersecting) {
          setTimeout(() => {
            entry.target.classList.add('card-revealed');
          }, index * 20);
          observer.unobserve(entry.target);
        }
      });
    }, {
      threshold: 0.1,
      rootMargin: '0px 0px -50px 0px'
    });

    cards.forEach((card) => {
      observer.observe(card);
    });
  }
</script>

<style>
  .filter-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1rem;
    background-color: hsl(var(--background));
    border: 2px solid hsl(var(--border));
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 600;
    color: hsl(var(--muted-foreground));
    cursor: pointer;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    font-family: inherit;
  }

  .filter-badge svg {
    transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .filter-badge:hover {
    background-color: hsl(var(--accent));
    border-color: hsl(var(--muted-foreground) / 0.3);
    transform: translateY(-2px);
  }

  .filter-badge.active {
    background-color: var(--badge-color, hsl(var(--primary)));
    border-color: var(--badge-color, hsl(var(--primary)));
    color: hsl(var(--primary-foreground));
    box-shadow: 0 4px 12px -2px var(--badge-color, hsl(var(--primary) / 0.4));
  }

  .filter-badge.active svg {
    transform: scale(1.1);
  }

  .filter-badge:active {
    transform: translateY(0);
  }

  .filter-badge[data-filter="hasHistoric"].active {
    --badge-color: #F59E0B;
  }

  .filter-badge[data-filter="hasNature"].active {
    --badge-color: #10B981;
  }

  .filter-badge[data-filter="hasSport"].active {
    --badge-color: #3B82F6;
  }

  .filter-badge[data-filter="hasFood"].active {
    --badge-color: #EF4444;
  }

  .filter-badge[data-filter="hasAccommodation"].active {
    --badge-color: #8B5CF6;
  }

  .filter-badge[data-filter="hasStation"].active {
    --badge-color: #6366F1;
  }

  .clear-filters {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1rem;
    background-color: hsl(0 84% 60% / 0.1);
    border: 2px solid hsl(0 84% 60% / 0.3);
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 600;
    color: hsl(var(--destructive));
    cursor: pointer;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    font-family: inherit;
  }

  .clear-filters:hover {
    background-color: hsl(0 84% 60% / 0.15);
    border-color: hsl(0 84% 60% / 0.5);
    transform: translateY(-2px);
  }

  .clear-filters:active {
    transform: translateY(0);
  }

  #comuni-grid > div {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  #comuni-grid > div.card-revealed {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 640px) {
    .filter-badge span,
    .clear-filters span {
      display: none;
    }
    
    .filter-badge,
    .clear-filters {
      padding: 0.625rem;
      width: 42px;
      height: 42px;
      justify-content: center;
    }
  }
</style>
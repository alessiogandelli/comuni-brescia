---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const comuni = await getCollection('comuni');
comuni.sort((a, b) => a.data.name.localeCompare(b.data.name, 'it'));

const base = import.meta.env.BASE_URL;
---

<Layout
  title="Comuni Brescia"
  description="Guida completa ai comuni della provincia di Brescia: storia, luoghi da visitare, popolazione e informazioni utili."
  canonicalUrl={`${import.meta.env.SITE}${base}/`}
>
  <section class="hero" style="margin: calc(-1 * var(--spacing-xl)) calc(-1 * var(--spacing-md)) var(--spacing-xl);">
    <h1>Comuni della Provincia di Brescia</h1>
    <p>Esplora i comuni bresciani: storia, cultura, luoghi da visitare e molto altro.</p>
  </section>

  <div class="stats-row">
    <span>📍 <strong>{comuni.length}</strong> comuni</span>
    <span>🏙️ Provincia di Brescia</span>
  </div>

  <div class="filter-bar">
    <input
      type="search"
      id="search-input"
      placeholder="Cerca un comune..."
      aria-label="Cerca un comune"
    />
  </div>

  <div class="card-grid" id="comuni-grid">
    {comuni.map((comune) => (
      <article class="card" data-name={comune.data.name.toLowerCase()}>
        <h2 class="card-title">{comune.data.name}</h2>
        <p class="card-meta">
          🏛️ Provincia {comune.data.province} &nbsp;·&nbsp;
          👥 {comune.data.population.toLocaleString('it-IT')} ab.
        </p>
        <a class="card-link" href={`${base}/comuni/${comune.slug}`}>
          Scopri {comune.data.name} →
        </a>
      </article>
    ))}
  </div>
</Layout>

<script>
  const input = document.getElementById('search-input') as HTMLInputElement;
  const cards = document.querySelectorAll<HTMLElement>('#comuni-grid .card');

  input?.addEventListener('input', () => {
    const query = input.value.toLowerCase().trim();
    cards.forEach((card) => {
      const name = card.dataset.name ?? '';
      card.style.display = name.includes(query) ? '' : 'none';
    });
  });
</script>

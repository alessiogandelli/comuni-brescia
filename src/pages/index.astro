---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import ComuneCard from '../components/ComuneCard.astro';
import Icon from '../components/Icon.astro';

const comuni = await getCollection('comuni');
comuni.sort((a, b) => a.data.name.localeCompare(b.data.name, 'it'));

const randomComune = comuni[Math.floor(Math.random() * comuni.length)];
const totalPopulation = comuni.reduce((sum, c) => sum + c.data.population, 0);
const totalArea = comuni.reduce((sum, c) => sum + (c.data.area || 0), 0);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout
  title="Comuni Brescia"
  description="Guida completa a tutti i comuni della provincia di Brescia: storia, luoghi da visitare, popolazione e informazioni utili per esplorare il territorio bresciano."
  canonicalUrl={`${import.meta.env.SITE}${base}/`}
>
  <div class="-mx-6 -my-12 px-6 py-16 mb-12 bg-primary text-primary-foreground rounded-3xl relative overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: url(&quot;data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E&quot;);"></div>
    <div class="relative z-10 text-center max-w-2xl mx-auto">
      <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-sm font-semibold bg-white/20 backdrop-blur-sm border border-white/30 mb-6">
        Comune del giorno
      </span>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black tracking-tight mb-4 leading-[1.05]">
        {randomComune.data.name}
      </h1>
      {randomComune.data.fact && (
        <p class="text-lg text-white/90 mb-8 max-w-xl mx-auto">{randomComune.data.fact}</p>
      )}
      <div class="flex flex-wrap justify-center gap-4">
        <a class="inline-flex items-center gap-2 px-6 py-3 bg-white text-primary font-bold rounded-xl hover:-translate-y-0.5 hover:shadow-lg transition-all" href={`${base}/comuni/${randomComune.id}`}>
          Scopri {randomComune.data.name}
          <Icon name="arrow-right" size={16} />
        </a>
        <button class="inline-flex items-center gap-2 px-6 py-3 bg-white/15 backdrop-blur-sm border-2 border-white/40 text-white font-semibold rounded-xl hover:bg-white/25 hover:-translate-y-0.5 transition-all" onclick="location.reload()">
          <Icon name="compass" size={16} />
          Altro comune
        </button>
      </div>
    </div>
  </div>

  <div class="flex flex-wrap justify-center items-center gap-6 px-4 py-4 bg-muted/50 border border-border rounded-xl mb-12 text-sm text-muted-foreground">
    <span><strong class="text-foreground font-semibold">{comuni.length}</strong> Comuni</span>
    <span class="text-border">·</span>
    <span><strong class="text-foreground font-semibold">{(totalPopulation / 1000000).toFixed(2)}M</strong> Abitanti</span>
    <span class="text-border">·</span>
    <span><strong class="text-foreground font-semibold">{Math.round(totalArea)}</strong> km² territorio</span>
  </div>

  <section>
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-foreground mb-2 tracking-tight">Comuni in evidenza</h2>
      <p class="text-muted-foreground max-w-md mx-auto">Alcuni dei comuni più interessanti da scoprire nella provincia di Brescia</p>
    </div>

    <div class="mb-6">
      <div class="relative">
        <Icon name="search" size={18} class="absolute left-4 top-1/2 -translate-y-1/2 text-muted-foreground pointer-events-none" />
        <input
          type="search"
          id="search-input"
          placeholder="Cerca un comune per nome..."
          aria-label="Cerca un comune"
          class="w-full pl-11 pr-4 py-3 border-2 border-input bg-background rounded-xl text-base outline-none transition-all placeholder:text-muted-foreground focus:border-primary focus:ring-4 focus:ring-primary/10 shadow-sm"
        />
      </div>
      <div id="filter-results" class="hidden text-center mt-3 text-sm text-muted-foreground font-medium"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="comuni-grid">
      {comuni.map((comune) => (
        <div data-name={comune.data.name.toLowerCase()}>
          <ComuneCard comune={{
            slug: comune.id,
            name: comune.data.name,
            population: comune.data.population,
            area: comune.data.area,
            elevation: comune.data.elevation,
            poiCount: comune.data.poiCount,
            hasHistoric: comune.data.hasHistoric,
            hasNature: comune.data.hasNature,
            hasSport: comune.data.hasSport,
            hasFood: comune.data.hasFood,
            hasAccommodation: comune.data.hasAccommodation,
            hasStation: comune.data.hasStation,
            fact: comune.data.fact,
          }} />
        </div>
      ))}
    </div>

    <div class="mt-12 text-center">
      <a class="inline-flex items-center gap-2 px-6 py-3 bg-background border-2 border-border text-foreground font-semibold rounded-xl hover:border-primary hover:text-primary hover:bg-primary/5 hover:-translate-y-0.5 hover:shadow-md transition-all" href={`${base}/comuni`}>
        Vedi tutti i {comuni.length} comuni
        <Icon name="arrow-right" size={16} />
      </a>
    </div>
  </section>
</Layout>

<script>
  const input = document.getElementById('search-input') as HTMLInputElement;
  const cards = document.querySelectorAll<HTMLElement>('#comuni-grid > div');
  const resultsDiv = document.getElementById('filter-results');

  function updateFilter() {
    const query = input.value.toLowerCase().trim();
    let visibleCount = 0;
    
    cards.forEach((card) => {
      const name = card.dataset.name ?? '';
      const isVisible = !query || name.includes(query);
      card.style.display = isVisible ? '' : 'none';
      if (isVisible) visibleCount++;
    });

    if (resultsDiv) {
      if (query) {
        resultsDiv.textContent = `${visibleCount} ${visibleCount === 1 ? 'comune trovato' : 'comuni trovati'}`;
        resultsDiv.classList.remove('hidden');
      } else {
        resultsDiv.classList.add('hidden');
      }
    }
  }

  input?.addEventListener('input', updateFilter);
  
  if (typeof IntersectionObserver !== 'undefined') {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry, index) => {
        if (entry.isIntersecting) {
          setTimeout(() => {
            entry.target.classList.add('card-revealed');
          }, index * 30);
          observer.unobserve(entry.target);
        }
      });
    }, {
      threshold: 0.1,
      rootMargin: '0px 0px -50px 0px'
    });

    document.querySelectorAll('#comuni-grid > div').forEach((card) => {
      observer.observe(card);
    });
  }
</script>

<style>
  #comuni-grid > div {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  #comuni-grid > div.card-revealed {
    opacity: 1;
    transform: translateY(0);
  }
</style>